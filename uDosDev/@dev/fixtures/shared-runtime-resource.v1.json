{
  "contract_id": "udos.shared-runtime-resource.v1",
  "owner": "uDOS-dev",
  "description": "Family-level shared runtime/resource baseline for Docker replacement.",
  "adapter": {
    "repo": "uDOS-host",
    "verify_script": "scripts/verify-udos-runtime-daemons.sh"
  },
  "required_health_endpoints": [
    "/health.json",
    "/v1/status"
  ],
  "required_lifecycle_operations": [
    "runtime.service.start",
    "runtime.service.stop",
    "runtime.service.restart",
    "runtime.service.status"
  ],
  "required_services": [
    "udos-hostd",
    "udos-commandd",
    "udos-vaultd",
    "udos-syncd",
    "udos-web",
    "udos-budgetd",
    "udos-networkd",
    "udos-scheduled",
    "udos-tuid",
    "udos-thinui",
    "udos-wizard-adapter"
  ]
}
