{
  "contract_id": "udos.operational-hygiene-venv-lanes.v1",
  "owner": "uDOS-dev",
  "description": "Repos whose primary check scripts must keep host-managed venv defaults under ~/.udos/venv (Post-08 O4 drift guard).",
  "lanes": [
    {
      "repo": "uDOS-wizard",
      "check_script": "scripts/run-wizard-checks.sh",
      "default_path_fragment": ".udos/venv/wizard"
    },
    {
      "repo": "uDOS-empire",
      "check_script": "scripts/run-empire-checks.sh",
      "default_path_fragment": ".udos/venv/empire"
    },
    {
      "repo": "uDOS-surface",
      "check_script": "scripts/run-wizard-checks.sh",
      "default_path_fragment": ".udos/venv/surface"
    }
  ],
  "optional_alt_roots": [
    {
      "env": "UDOS_SONIC_SCREWDRIVER_ROOT",
      "repo": "sonic-screwdriver",
      "check_script": "scripts/run-sonic-checks.sh",
      "default_path_fragment": ".udos/venv/sonic-screwdriver"
    }
  ]
}
