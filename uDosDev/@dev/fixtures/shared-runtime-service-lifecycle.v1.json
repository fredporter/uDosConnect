{
  "contract_id": "udos.shared-runtime-service-lifecycle.v1",
  "owner": "uDOS-dev",
  "description": "Service lifecycle matrix for shared runtime/resource contract.",
  "mode": "lane1-noop",
  "services": [
    "udos-hostd",
    "udos-commandd",
    "udos-vaultd",
    "udos-syncd",
    "udos-web",
    "udos-budgetd",
    "udos-networkd",
    "udos-scheduled",
    "udos-tuid",
    "udos-thinui",
    "udos-wizard-adapter"
  ],
  "optional_compat_services": [
    {
      "service_id": "groovebox-songscribe-ui",
      "control_profile": "docker-fallback",
      "owner_repo": "uDOS-groovebox",
      "notes": "Transitional compatibility lane; non-Docker default remains primary."
    },
    {
      "service_id": "groovebox-songscribe-api",
      "control_profile": "external-compat",
      "owner_repo": "uDOS-groovebox",
      "notes": "Upstream API lane; integrate to shared runtime lifecycle in later phase."
    },
    {
      "service_id": "ubuntu-wordpress-publish-stack",
      "control_profile": "docker-fallback",
      "owner_repo": "uDOS-host",
      "notes": "Transitional publish/demo stack under @dev/udos-ubuntu-v2/publish/wordpress/docker; not a tier-1 host daemon. Migration target: host-native or shared runtime adapter when scheduled."
    }
  ],
  "operation_expectations": {
    "runtime.service.start": {
      "status": "accepted",
      "mode": "lane1-noop"
    },
    "runtime.service.stop": {
      "status": "accepted",
      "mode": "lane1-noop"
    },
    "runtime.service.restart": {
      "status": "accepted",
      "mode": "lane1-noop"
    },
    "runtime.service.status": {
      "status": "ok",
      "state": "lane1-minimal"
    }
  }
}
