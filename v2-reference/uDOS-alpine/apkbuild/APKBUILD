pkgname=udos-alpine-profile
pkgver=0.1.0
pkgrel=0
pkgdesc="uDOS Alpine ThinUI launch profile and OpenRC handoff"
arch="all"
license="MIT"
depends="openrc"
source=""

build() {
    return 0
}

package() {
    install -d "$pkgdir/usr/share/udos-alpine/profiles"
    install -d "$pkgdir/etc/init.d"
    install -d "$pkgdir/etc/conf.d"

    install -m644 "$srcdir/../profiles/thinui-c64-launch.json" \
        "$pkgdir/usr/share/udos-alpine/profiles/thinui-c64-launch.json"
    install -m755 "$srcdir/../openrc/udos-thinui-launcher.initd" \
        "$pkgdir/etc/init.d/udos-thinui-launcher"
    install -m644 "$srcdir/../openrc/udos-thinui-launcher.confd" \
        "$pkgdir/etc/conf.d/udos-thinui-launcher"
}
