runtime_profile: ubuntu-command-centre
paths:
  home: "~/.udos"
  state: "~/.udos/state"
  vault: "~/.udos/vault"
  publish: "~/.udos/publish"
  sync: "~/.udos/sync"
  repos: "~/.udos/repos"
  repo_registry: "~/.udos/state/gitd/repo-registry.tsv"
  logs: "~/.udos/logs"
  cache: "~/.udos/cache"
  tmp: "~/.udos/tmp"
ports:
  hostd: 7100
  commandd: 7101
  vaultd: 7102
  syncd: 7103
  scheduled: 7104
  networkd: 7105
  budgetd: 7106
  web: 7107
  wizard_adapter: 7108
  gitd: 7109
