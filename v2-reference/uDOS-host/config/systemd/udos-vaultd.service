[Unit]
Description=uDOS vault service
After=udos-commandd.service
Requires=udos-commandd.service

[Service]
Type=simple
EnvironmentFile=/etc/udos/udos.env
ExecStart=/usr/bin/env bash -lc '"${UDOS_INSTALL_ROOT:-/opt/udos}/scripts/udos-vaultd.sh"'
Restart=on-failure

[Install]
WantedBy=multi-user.target
