UDOS_INSTALL_ROOT=/opt/udos
UDOS_HOME=%h/.udos
UDOS_REPOS_ROOT=%h/.udos/repos
UDOS_GITD_REGISTRY_PATH=%h/.udos/state/gitd/repo-registry.tsv
UDOS_RUNTIME_PROFILE=ubuntu-command-centre
UDOS_HOSTD_PORT=7100
UDOS_WEB_PORT=7107
UDOS_COMMANDD_PORT=7101
UDOS_VAULTD_PORT=7102
UDOS_SYNCD_PORT=7103
UDOS_SCHEDULED_PORT=7104
UDOS_NETWORKD_PORT=7105
UDOS_BUDGETD_PORT=7106
UDOS_TUID_PORT=0
UDOS_THINUI_PORT=0
UDOS_GITD_PORT=7109

# Optional: uDOS-surface experience profile hints (ThinUI lane-1 HTTP /v1/status, Shell help).
# UDOS_SURFACE_REPO=/path/to/uDOS-surface
# UDOS_SURFACE_PROFILE_ID=ubuntu-gnome
# UDOS_SURFACE_PROFILE_FILE=/path/to/uDOS-surface/profiles/ubuntu-gnome/surface.json
# UDOS_SURFACE_INPUT_MAPPING=/path/to/uDOS-surface/profiles/ubuntu-gnome/input-mapping.json
