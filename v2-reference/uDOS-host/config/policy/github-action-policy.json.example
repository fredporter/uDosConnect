{
  "version": "v1",
  "policy_id": "ubuntu-github-action-policy",
  "owner": "uDOS-host",
  "default_mode": "manual-approval",
  "audit_log": "~/.udos/logs/commandd/github-action-audit.log",
  "repo_rules": {
    "repo.fetch": {
      "mode": "allow"
    },
    "repo.branch": {
      "mode": "allow"
    },
    "repo.pull": {
      "mode": "allow"
    },
    "repo.push": {
      "mode": "require-approval",
      "approval_env": "UDOS_ALLOW_GIT_PUSH",
      "reason": "Outbound branch publication mutates remotes and must stay operator-approved."
    },
    "repo.clone_or_attach": {
      "mode": "allow"
    }
  },
  "github_rules": {
    "github.issue.read": {
      "mode": "require-adapter",
      "adapter": "gh-or-mcp"
    },
    "github.pr.comment": {
      "mode": "require-approval",
      "approval_env": "UDOS_ALLOW_GITHUB_WRITE",
      "adapter": "gh-or-mcp"
    },
    "github.pr.create": {
      "mode": "require-approval",
      "approval_env": "UDOS_ALLOW_GITHUB_WRITE",
      "adapter": "gh-or-mcp"
    }
  }
}
