[Unit]
Description=uDOS GPT Export Helper
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/udos-host/services/gpt-export-helper
Environment=PORT=3000
Environment=PUBLIC_BASE_URL=https://YOUR-DOMAIN.example
ExecStart=/usr/bin/node /opt/udos-host/services/gpt-export-helper/server.js
Restart=always
RestartSec=5
User=ubuntu

[Install]
WantedBy=multi-user.target
