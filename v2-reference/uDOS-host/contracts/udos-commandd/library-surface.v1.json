{
  "version": "v1",
  "surface_id": "ubuntu-library-surface",
  "owner": "uDOS-host",
  "service_id": "uDOS-host",
  "surface": "library",
  "transport": "local-http",
  "offline_safe": true,
  "dispatch_mode": "direct",
  "purpose": "Expose the Ubuntu-hosted local library and binder views as a broker-discoverable family surface.",
  "capabilities": [
    "library.browse",
    "library.search",
    "binder.view"
  ],
  "routes": [
    {
      "method": "GET",
      "path": "/library",
      "capability": "library.browse"
    },
    {
      "method": "GET",
      "path": "/library/search",
      "capability": "library.search"
    },
    {
      "method": "GET",
      "path": "/binders/{id}",
      "capability": "binder.view"
    }
  ]
}
