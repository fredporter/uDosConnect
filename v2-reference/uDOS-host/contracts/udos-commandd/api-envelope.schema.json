{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.family/contracts/udos-commandd/api-envelope.schema.json",
  "title": "uDOS commandd API envelope",
  "type": "object",
  "required": [
    "request"
  ],
  "properties": {
    "request": {
      "$ref": "#/$defs/requestEnvelope"
    },
    "result": {
      "$ref": "#/$defs/resultEnvelope"
    }
  },
  "$defs": {
    "surface": {
      "type": "string",
      "enum": [
        "tui",
        "web",
        "thinui",
        "service"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "accepted",
        "blocked",
        "degraded",
        "error"
      ]
    },
    "actor": {
      "type": "object",
      "required": [
        "id",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "uiHints": {
      "type": "object",
      "properties": {
        "preferred_view": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "allowed",
        "approval_required"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "budget": {
      "type": "object",
      "required": [
        "checked",
        "allowed"
      ],
      "properties": {
        "checked": {
          "type": "boolean"
        },
        "allowed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "nextAction": {
      "type": "object",
      "required": [
        "operation_id",
        "label"
      ],
      "properties": {
        "operation_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "errorItem": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "requestEnvelope": {
      "type": "object",
      "required": [
        "operation_id",
        "request_id",
        "session_id",
        "surface",
        "actor"
      ],
      "properties": {
        "operation_id": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "actor": {
          "$ref": "#/$defs/actor"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "params": {
          "type": "object"
        },
        "context": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "resultEnvelope": {
      "type": "object",
      "required": [
        "request_id",
        "operation_id",
        "status",
        "summary",
        "payload",
        "ui_hints",
        "policy",
        "budget",
        "errors",
        "next_actions",
        "meta"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "operation_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object"
        },
        "ui_hints": {
          "$ref": "#/$defs/uiHints"
        },
        "policy": {
          "$ref": "#/$defs/policy"
        },
        "budget": {
          "$ref": "#/$defs/budget"
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/errorItem"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nextAction"
          }
        },
        "meta": {
          "type": "object",
          "required": [
            "service",
            "timestamp"
          ],
          "properties": {
            "service": {
              "type": "string"
            },
            "timestamp": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
