{
  "version": "v1",
  "surface_id": "ubuntu-git-host-surface",
  "owner": "uDOS-host",
  "consumer": "family",
  "purpose": "Expose Ubuntu-owned local repo-store and Git or GitHub execution operations without making Empire or Wizard the canonical host owner.",
  "base_path": "/repos",
  "operations": [
    {
      "route": "/repos",
      "operation_id": "repo.list",
      "owner_service": "udos-gitd",
      "method": "GET"
    },
    {
      "route": "/repos/{repo_id}/status",
      "operation_id": "repo.status",
      "owner_service": "udos-gitd",
      "method": "GET"
    },
    {
      "route": "/repos/{repo_id}/fetch",
      "operation_id": "repo.fetch",
      "owner_service": "udos-gitd",
      "method": "POST"
    },
    {
      "route": "/repos/{repo_id}/branch",
      "operation_id": "repo.branch",
      "owner_service": "udos-gitd",
      "method": "POST"
    },
    {
      "route": "/repos/{repo_id}/pull",
      "operation_id": "repo.pull",
      "owner_service": "udos-gitd",
      "method": "POST"
    },
    {
      "route": "/repos/{repo_id}/push",
      "operation_id": "repo.push",
      "owner_service": "udos-gitd",
      "method": "POST"
    },
    {
      "route": "/repos/attach",
      "operation_id": "repo.clone_or_attach",
      "owner_service": "udos-gitd",
      "method": "POST"
    },
    {
      "route": "/repos/{repo_id}/github/pulls",
      "operation_id": "github.pr.create",
      "owner_service": "udos-gitd",
      "method": "POST"
    },
    {
      "route": "/repos/{repo_id}/github/issues/{issue_id}",
      "operation_id": "github.issue.read",
      "owner_service": "udos-gitd",
      "method": "GET"
    },
    {
      "route": "/repos/{repo_id}/github/issues/{issue_id}/comments",
      "operation_id": "github.pr.comment",
      "owner_service": "udos-gitd",
      "method": "POST"
    }
  ],
  "adapter_rule": {
    "policy_source": "config/policy/github-action-policy.json.example",
    "notes": [
      "Git is the base execution tool for repo-state mutations.",
      "GitHub CLI and MCP act as Ubuntu-hosted adapters behind these operations.",
      "Policy, credentials, and approval rules remain Ubuntu-owned."
    ]
  }
}
