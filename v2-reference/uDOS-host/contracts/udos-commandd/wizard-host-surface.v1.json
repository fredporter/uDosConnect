{
  "version": "v1",
  "surface_id": "wizard-browser-host-bridge",
  "owner": "uDOS-host",
  "consumer": "uDOS-wizard",
  "purpose": "Expose Ubuntu-owned host operations to Wizard browser surfaces without making Wizard the canonical config or runtime owner.",
  "base_path": "/host",
  "operations": [
    {
      "route": "/host/contract",
      "operation_id": "runtime.host.surface.contract",
      "owner_service": "udos-commandd",
      "method": "GET"
    },
    {
      "route": "/host/runtime-summary",
      "operation_id": "runtime.host.summary",
      "owner_service": "udos-commandd",
      "method": "GET"
    },
    {
      "route": "/host/local-state",
      "operation_id": "runtime.host.local-state.get",
      "owner_service": "udos-commandd",
      "method": "GET"
    },
    {
      "route": "/host/local-state",
      "operation_id": "runtime.host.local-state.set",
      "owner_service": "udos-commandd",
      "method": "POST"
    },
    {
      "route": "/host/secrets",
      "operation_id": "runtime.host.secrets.list",
      "owner_service": "udos-commandd",
      "method": "GET"
    },
    {
      "route": "/host/secrets",
      "operation_id": "runtime.host.secrets.set",
      "owner_service": "udos-commandd",
      "method": "POST"
    },
    {
      "route": "/host/budget-status",
      "operation_id": "runtime.host.budget.status",
      "owner_service": "udos-commandd",
      "method": "GET"
    },
    {
      "route": "/host/providers",
      "operation_id": "runtime.host.providers.list",
      "owner_service": "udos-commandd",
      "method": "GET"
    },
    {
      "route": "/host/orchestration-status",
      "operation_id": "runtime.host.orchestration.status",
      "owner_service": "udos-commandd",
      "method": "GET"
    }
  ],
  "wizard_rule": {
    "mode": "consumer",
    "deprecated_routes": [
      "/config/runtime",
      "/config/runtime-summary",
      "/config/local-state",
      "/config/secrets"
    ],
    "notes": [
      "Wizard may proxy or present these operations.",
      "Ubuntu remains the canonical owner of host config, secrets, and runtime summary."
    ]
  }
}
