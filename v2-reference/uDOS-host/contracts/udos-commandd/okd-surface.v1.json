{
  "version": "v1",
  "surface_id": "ubuntu-okd-surface",
  "owner": "uDOS-host",
  "service_id": "uDOS-host",
  "surface": "okd",
  "transport": "local-http",
  "offline_safe": false,
  "dispatch_mode": "direct",
  "purpose": "Expose Ubuntu OK execution as a family-discoverable broker target without moving execution authority out of Ubuntu.",
  "capabilities": [
    "ok.transformation",
    "ok.research",
    "ok.ingest"
  ],
  "routes": [
    {
      "method": "POST",
      "path": "/ok/run",
      "capability": "ok.transformation"
    },
    {
      "method": "POST",
      "path": "/ok/format",
      "capability": "ok.transformation"
    },
    {
      "method": "POST",
      "path": "/ok/research",
      "capability": "ok.research"
    },
    {
      "method": "POST",
      "path": "/ok/ingest/link",
      "capability": "ok.ingest"
    },
    {
      "method": "POST",
      "path": "/ok/ingest/topic",
      "capability": "ok.ingest"
    },
    {
      "method": "POST",
      "path": "/ok/ingest/file",
      "capability": "ok.ingest"
    },
    {
      "method": "GET",
      "path": "/ok/status/{id}",
      "capability": "ok.transformation"
    }
  ]
}
