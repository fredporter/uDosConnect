{
  "profile": "always-on-local-mirror-cache-host",
  "owner": "uDOS-host",
  "remote_lane": "google-mvp-a",
  "local_defaults": {
    "cache_enabled": true,
    "artifact_staging": "local-authoritative",
    "workstation_shell": "browser-first",
    "degraded_mode_visible": true
  },
  "remote_features": {
    "firestore_mirror": "optional",
    "firebase_auth_shared_room": "optional",
    "cloud_run_trigger": "empire-supervised"
  },
  "fallback_rules": {
    "when_remote_unavailable": [
      "continue_local_runtime",
      "serve_last_known_cache",
      "queue_mirror_sync",
      "show_degraded_mode"
    ],
    "canonical_truth": "local vault and family-owned extracted artifacts"
  }
}
