{
  "version": "v2.2.1",
  "theme": "browser-default",
  "owner": "uDOS-themes",
  "surface": "cross-surface",
  "layers": [
    "base-tokens",
    "component-primitives",
    "surface-adapters",
    "skins"
  ],
  "tokens": {
    "color": {
      "accent": "#1d5c63",
      "background": "#f8f5ee",
      "foreground": "#1d2728",
      "muted": "#708281"
    },
    "typography": {
      "heading": "Fraunces, serif",
      "body": "Source Serif 4, serif",
      "mono": "IBM Plex Mono, monospace"
    },
    "spacing": {
      "unit": 8,
      "compact": 4,
      "roomy": 12
    },
    "radius": {
      "sm": 4,
      "md": 10,
      "lg": 18
    },
    "border": {
      "default": "1px solid #c8d3d1",
      "strong": "2px solid #1d5c63"
    },
    "shadow": {
      "soft": "0 8px 30px rgba(29,92,99,0.12)"
    },
    "motion": {
      "page_enter_ms": 220,
      "step_transition_ms": 160
    },
    "density": {
      "default": "comfortable"
    },
    "surface": {
      "panel": "#fffcf7",
      "overlay": "#edf3f2"
    },
    "state": {
      "success": "#2b7d4a",
      "warning": "#c7891f",
      "error": "#b33f3f"
    },
    "feedback": {
      "info": "#215d8f",
      "help": "#5a4b8a"
    },
    "focus": {
      "ring": "#1d5c63"
    },
    "input": {
      "background": "#ffffff",
      "foreground": "#1d2728",
      "placeholder": "#708281"
    }
  }
}
