{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/loader-patterns.schema.json",
  "title": "uDOS Loader Pattern",
  "type": "object",
  "required": ["id", "label", "surfaceTargets", "sequenceType", "frames", "fallback"],
  "properties": {
    "id": { "type": "string" },
    "label": { "type": "string" },
    "surfaceTargets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sequenceType": {
      "type": "string",
      "enum": ["frame-list", "step-list", "pulse", "scan", "bar"]
    },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "text"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "text": { "type": "string" },
          "durationMs": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "fallback": {
      "type": "object",
      "required": ["mode", "text"],
      "properties": {
        "mode": { "type": "string", "enum": ["static", "reduced-motion", "text-only"] },
        "text": { "type": "string" }
      }
    }
  }
}
