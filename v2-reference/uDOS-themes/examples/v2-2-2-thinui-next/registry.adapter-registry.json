{
  "$schema": "./schemas/adapter-registry.schema.json",
  "version": "2.2.1",
  "adapters": [
    {
      "id": "browser.default.v1",
      "surfaceTargets": ["browser"],
      "themeIds": ["browser-default"],
      "capabilities": ["cards", "forms", "lists", "panels", "responsive-layout"]
    },
    {
      "id": "thinui.c64.v1",
      "surfaceTargets": ["thinui", "alpine"],
      "themeIds": ["thinui-c64"],
      "capabilities": ["fullscreen", "boot-loader", "menu-list", "status-footer", "low-resource-mode"]
    },
    {
      "id": "wizard.notion.v1",
      "surfaceTargets": ["wizard-browser"],
      "themeIds": ["wizard-notion"],
      "capabilities": ["kanban", "task-cards", "schedules", "notes", "queues"]
    },
    {
      "id": "thinui.nes-sonic.v1",
      "surfaceTargets": ["thinui", "sonic-screwdriver"],
      "themeIds": ["thinui-nes-sonic"],
      "capabilities": ["utility-panels", "selector-grid", "diagnostics", "compact-cards", "controller-focus"]
    }
  ]
}
