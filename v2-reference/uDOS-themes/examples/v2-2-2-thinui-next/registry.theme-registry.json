{
  "$schema": "./schemas/theme-registry.schema.json",
  "version": "2.2.1",
  "themes": [
    {
      "id": "browser-default",
      "label": "Browser Default",
      "family": "browser",
      "surfaceTargets": ["browser"],
      "stack": ["svelte", "tailwind"],
      "default": true,
      "adapterIds": ["browser.default.v1"],
      "fontIds": [],
      "loaderIds": ["binder-pulse"]
    },
    {
      "id": "thinui-c64",
      "label": "Thinui C64",
      "family": "thinui",
      "surfaceTargets": ["thinui", "alpine"],
      "stack": ["thinui", "c64css3-fork", "petme"],
      "default": false,
      "adapterIds": ["thinui.c64.v1"],
      "fontIds": ["petme"],
      "loaderIds": ["boot-grid", "tape-stripe", "drive-chunk"]
    },
    {
      "id": "wizard-notion",
      "label": "Wizard Notion",
      "family": "wizard",
      "surfaceTargets": ["wizard-browser"],
      "stack": ["svelte", "svelte-notion-kit-fork"],
      "default": false,
      "adapterIds": ["wizard.notion.v1"],
      "fontIds": [],
      "loaderIds": ["OK-wait"]
    },
    {
      "id": "thinui-nes-sonic",
      "label": "Thinui NES Sonic",
      "family": "thinui",
      "surfaceTargets": ["thinui", "sonic-screwdriver"],
      "stack": ["thinui", "nes-css-fork", "sonic-screwdriver"],
      "default": false,
      "adapterIds": ["thinui.nes-sonic.v1"],
      "fontIds": [],
      "loaderIds": ["binder-pulse", "sync-scan"]
    }
  ]
}
