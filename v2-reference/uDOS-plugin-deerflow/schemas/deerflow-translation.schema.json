{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "uDOS Deer Flow Translation",
  "type": "object",
  "required": [
    "translationVersion",
    "workflowId",
    "generatedAt",
    "upstream",
    "nodes",
    "edges",
    "policy"
  ],
  "properties": {
    "translationVersion": {
      "type": "string"
    },
    "workflowId": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "upstream": {
      "type": "object",
      "required": [
        "repo",
        "pinType",
        "pin"
      ],
      "properties": {
        "repo": {
          "type": "string"
        },
        "pinType": {
          "type": "string",
          "enum": [
            "tag",
            "commit",
            "branch"
          ]
        },
        "pin": {
          "type": "string"
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "trustClass",
        "networkProfile",
        "filesystemProfile"
      ],
      "properties": {
        "trustClass": {
          "type": "string"
        },
        "networkProfile": {
          "type": "string"
        },
        "filesystemProfile": {
          "type": "string"
        }
      }
    }
  }
}