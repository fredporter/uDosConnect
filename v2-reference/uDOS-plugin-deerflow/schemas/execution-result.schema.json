{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "uDOS Deer Flow Execution Result",
  "type": "object",
  "required": [
    "executionId",
    "workflowId",
    "status",
    "startedAt",
    "finishedAt",
    "upstream",
    "summary",
    "nodes"
  ],
  "properties": {
    "executionId": {
      "type": "string"
    },
    "workflowId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed",
        "denied",
        "dry-run"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "upstream": {
      "type": "object",
      "required": [
        "repo",
        "pinType",
        "pin"
      ],
      "properties": {
        "repo": {
          "type": "string"
        },
        "pinType": {
          "type": "string"
        },
        "pin": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "completed",
        "failed",
        "artifactsProduced"
      ],
      "properties": {
        "completed": {
          "type": "integer"
        },
        "failed": {
          "type": "integer"
        },
        "artifactsProduced": {
          "type": "integer"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "artifactPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}