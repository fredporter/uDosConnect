{
  "version": "v2.0.4",
  "owner": "uDOS-grid",
  "summary": "Canonical place record contract for Grid-owned spatial identity and deterministic place resolution.",
  "canonical_id_formats": {
    "short": "L{Layer}-{Cell}[-Z{z}]",
    "place_ref": "ANCHOR:SPACE:LAYER-CELL[-Z]"
  },
  "required_fields": [
    "place_id",
    "name",
    "layer",
    "cell",
    "space",
    "anchor"
  ],
  "optional_fields": [
    "z",
    "kind",
    "domain",
    "region",
    "country",
    "continent",
    "timezone",
    "aliases",
    "seed",
    "coordinates",
    "tags",
    "metadata"
  ],
  "allowed_space_values": [
    "SUR",
    "SUB",
    "UDN",
    "ORB",
    "COS"
  ],
  "seed_geometry": {
    "cols": 80,
    "rows": 30,
    "cell_format": "[A-Z]{2}[1-9][0-9]?"
  },
  "resolution_order": [
    "anchor",
    "space",
    "layer",
    "cell",
    "z"
  ],
  "consumers": [
    "uDOS-shell",
    "uDOS-wizard",
    "uDOS-gameplay",
    "uHOME-server",
    "uDOS-empire",
    "omd-mac-osx-app"
  ]
}
