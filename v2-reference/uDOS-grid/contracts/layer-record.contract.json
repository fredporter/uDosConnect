{
  "version": "v2.0.4",
  "owner": "uDOS-grid",
  "summary": "Canonical layer record contract for Grid-owned spatial planes, domain anchors, and seed bands.",
  "required_fields": [
    "layer_id",
    "anchor",
    "space",
    "domain",
    "cols",
    "rows",
    "seed"
  ],
  "optional_fields": [
    "band",
    "kind",
    "world",
    "seed_scope",
    "notes",
    "review_status"
  ],
  "allowed_domains": [
    "terrestrial",
    "terrestrial-subsurface",
    "virtual",
    "planetary",
    "orbital",
    "stellar"
  ],
  "allowed_space_values": [
    "SUR",
    "SUB",
    "UDN",
    "ORB",
    "COS"
  ],
  "geometry_rule": {
    "cols": 80,
    "rows": 30,
    "note": "Seed layers preserve ASCII and text-first map compatibility."
  },
  "consumers": [
    "uDOS-shell",
    "uDOS-wizard",
    "uDOS-gameplay",
    "uHOME-server"
  ]
}
