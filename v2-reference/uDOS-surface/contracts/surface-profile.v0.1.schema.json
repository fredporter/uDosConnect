{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "udos:surface-profile.v0.1",
  "title": "uDOS surface profile (ThinUI hosting contract)",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "layout", "navigation", "input", "modes", "thinui", "session"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$",
      "description": "Stable profile slug (e.g. ubuntu-gnome)."
    },
    "schemaVersion": {
      "type": "string",
      "description": "Contract revision for this file shape."
    },
    "layout": {
      "type": "string",
      "description": "Layout mode id (split, single, focus, …)."
    },
    "navigation": {
      "type": "string",
      "description": "Navigation model id (panel, stack, …)."
    },
    "input": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Primary input channels for this surface."
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["windowed", "fullscreen"]
      },
      "minItems": 1,
      "description": "Allowed ThinUI session geometry modes."
    },
    "thinui": {
      "type": "object",
      "additionalProperties": true,
      "required": ["density", "theme", "components"],
      "properties": {
        "density": { "type": "string" },
        "theme": { "type": "string", "description": "Theme id resolved by ThinUI (e.g. udos-default)." },
        "components": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": true,
      "required": ["multiWindow", "restoreState"],
      "properties": {
        "multiWindow": { "type": "boolean" },
        "restoreState": { "type": "boolean" }
      }
    }
  }
}
