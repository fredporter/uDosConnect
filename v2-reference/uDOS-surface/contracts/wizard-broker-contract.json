{
  "version": "v1",
  "owner": "uDOS-wizard",
  "service_id": "uDOS-wizard",
  "surface": "broker",
  "transport": "https",
  "offline_safe": true,
  "dispatch_mode": "direct",
  "package": "wizard-broker-contract",
  "purpose": "Resolve family requests to the correct service and return delegation envelopes without taking execution authority.",
  "capabilities": [
    "wizard.services",
    "wizard.resolve"
  ],
  "routes": {
    "services": {
      "method": "GET",
      "path": "/wizard/services"
    },
    "resolve": {
      "method": "POST",
      "path": "/wizard/resolve",
      "body": [
        "intent",
        "capability",
        "offline_only",
        "approval_required",
        "payload_ref"
      ]
    },
    "dispatch": {
      "method": "POST",
      "path": "/wizard/dispatch",
      "body": [
        "intent",
        "capability",
        "payload",
        "offline_only",
        "approval_required",
        "payload_ref"
      ]
    }
  },
  "resolve_contract": {
    "result_statuses": [
      "delegated",
      "multiple_candidates",
      "blocked_by_policy",
      "unsupported",
      "help"
    ],
    "required_fields": [
      "request_id",
      "broker",
      "status",
      "intent",
      "capability"
    ]
  },
  "dispatch_contract": {
    "result_statuses": [
      "dispatched",
      "delegated",
      "multiple_candidates",
      "blocked_by_policy",
      "unsupported",
      "help"
    ],
    "required_fields": [
      "request_id",
      "broker",
      "status",
      "intent",
      "capability"
    ]
  }
}
