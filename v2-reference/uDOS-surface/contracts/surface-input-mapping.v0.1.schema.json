{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "udos:surface-input-mapping.v0.1",
  "title": "uDOS surface input mapping (intents for Shell / UCI)",
  "type": "object",
  "additionalProperties": true,
  "required": ["profileId", "schemaVersion", "primaryInput"],
  "properties": {
    "profileId": { "type": "string" },
    "schemaVersion": { "type": "string" },
    "description": { "type": "string" },
    "primaryInput": { "type": "string" },
    "secondaryInput": {
      "type": "array",
      "items": { "type": "string" }
    },
    "keyboard": { "type": "object", "additionalProperties": true },
    "controller": { "type": "object", "additionalProperties": true }
  }
}
