{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UCI Controller Mapping",
  "type": "object",
  "required": [
    "version",
    "profile_id",
    "actions"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "profile_id": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "control",
          "mode",
          "semantic_action"
        ],
        "properties": {
          "control": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "nav",
              "text",
              "command",
              "edit",
              "game",
              "media"
            ]
          },
          "semantic_action": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
