{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/feed-item-contract.schema.json",
  "title": "uDOS Feed Item Contract",
  "type": "object",
  "required": ["id", "ts", "feed_type", "summary"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "feed_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
