{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/feed-create-request-contract.schema.json",
  "title": "uDOS Feed Create Request Contract",
  "type": "object",
  "required": ["source", "transform", "output"],
  "properties": {
    "source": {
      "type": "object",
      "properties": {
        "spool": {
          "type": "string"
        },
        "binder": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selection_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "transform": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "digest", "derived"]
        },
        "group_by": {
          "type": "string",
          "enum": ["none", "hour", "day", "week", "month"]
        },
        "compact": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": ["json", "rss", "atom", "markdown", "csv", "sqlite"]
        },
        "target": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": ["private", "workspace", "public"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
