{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.family/schemas/binder-spine-payload.v1.schema.json",
  "title": "Binder spine payload (v1)",
  "description": "JSON shape for binder-native workspace payloads (ThinUI unified workspace demo, workspace operator state). Family plan v2.6 Round A (Core).",
  "type": "object",
  "required": ["schema_version", "id", "title", "items"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "title", "recordType"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "recordType": { "type": "string", "minLength": 1 },
        "parentId": { "type": ["string", "null"] },
        "docSlug": { "type": "string" },
        "summary": { "type": "string" },
        "markdown": { "type": "string" },
        "status": { "type": "string" },
        "dueAt": { "type": "string" },
        "scheduledAt": { "type": "string" },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "campaignId": { "type": "string" },
        "postState": { "type": "string" },
        "fields": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}
