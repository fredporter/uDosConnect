{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MDC Output Contract",
  "type": "object",
  "required": [
    "source_path",
    "source_type",
    "classifier",
    "outputs"
  ],
  "properties": {
    "source_path": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "classifier": {
      "type": "string"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "markdown",
              "json",
              "sqlite"
            ]
          },
          "path": {
            "type": "string"
          },
          "deterministic": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
