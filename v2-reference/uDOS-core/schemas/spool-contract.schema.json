{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/spool-contract.schema.json",
  "title": "uDOS Spool Contract",
  "type": "object",
  "required": ["id", "name", "format", "items"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": ["json", "xml", "hybrid"]
    },
    "description": {
      "type": "string"
    },
    "checkpoint": {
      "type": "string"
    },
    "retention_class": {
      "type": "string"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "https://udos.dev/schemas/feed-item-contract.schema.json"
      }
    }
  },
  "additionalProperties": true
}
