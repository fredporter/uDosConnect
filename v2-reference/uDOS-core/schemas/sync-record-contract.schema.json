{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/sync-record-contract.schema.json",
  "title": "uDOS Sync Record Contract",
  "type": "object",
  "required": [
    "contract_version",
    "contacts",
    "activities",
    "binders",
    "sync_metadata"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "v2.0.4"
    },
    "contacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/canonical_contact"
      }
    },
    "activities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activity"
      }
    },
    "binders": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/binder_project"
      }
    },
    "sync_metadata": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sync_metadata"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "contact_id": {
      "type": "string",
      "pattern": "^contact:[a-z0-9][a-z0-9._-]*$"
    },
    "activity_id": {
      "type": "string",
      "pattern": "^activity:[a-z0-9][a-z0-9._-]*$"
    },
    "binder_id": {
      "type": "string",
      "pattern": "^(binder|project):[a-z0-9][a-z0-9._-]*$"
    },
    "sync_id": {
      "type": "string",
      "pattern": "^sync:[a-z0-9][a-z0-9._-]*$"
    },
    "entity_ref": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["contact", "company", "binder", "project", "activity"]
        },
        "id": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "labeled_value": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "value": {
          "$ref": "#/$defs/non_empty_string"
        },
        "primary": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "address": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postcode": {
          "type": "string"
        },
        "state_region": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "external_ref": {
      "type": "object",
      "required": ["system", "ref"],
      "properties": {
        "system": {
          "type": "string",
          "enum": [
            "apple_contacts",
            "vault_contacts_db",
            "hubspot",
            "google",
            "manual",
            "local_network"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "matched": {
          "type": "boolean"
        },
        "merge_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "source_provenance": {
      "type": "object",
      "required": ["source", "observed_at"],
      "properties": {
        "source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "$ref": "#/$defs/timestamp"
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sync_state": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["pending", "running", "synced", "conflict", "error", "skipped"]
        },
        "fingerprint": {
          "type": "object",
          "properties": {
            "content_hash": {
              "type": "string"
            },
            "source_etag": {
              "type": "string"
            },
            "target_etag": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "last_attempt_at": {
          "$ref": "#/$defs/timestamp"
        },
        "last_success_at": {
          "$ref": "#/$defs/timestamp"
        },
        "error_code": {
          "type": "string"
        },
        "error_message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "canonical_contact": {
      "type": "object",
      "required": [
        "contact_id",
        "entity_type",
        "display_name",
        "emails",
        "phones",
        "addresses",
        "external_refs",
        "source_provenance",
        "first_seen_at",
        "last_seen_at"
      ],
      "properties": {
        "contact_id": {
          "$ref": "#/$defs/contact_id"
        },
        "entity_type": {
          "const": "canonical_contact"
        },
        "display_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "given_name": {
          "type": "string"
        },
        "family_name": {
          "type": "string"
        },
        "role_title": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "relationship": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "emails": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labeled_value"
          }
        },
        "phones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labeled_value"
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/address"
          }
        },
        "websites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labeled_value"
          }
        },
        "social_profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["platform", "handle"],
            "properties": {
              "platform": {
                "type": "string",
                "enum": ["facebook", "instagram", "linkedin", "other"]
              },
              "handle": {
                "$ref": "#/$defs/non_empty_string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        },
        "external_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_ref"
          }
        },
        "source_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_provenance"
          }
        },
        "first_seen_at": {
          "$ref": "#/$defs/timestamp"
        },
        "last_seen_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "additionalProperties": false
    },
    "activity": {
      "type": "object",
      "required": [
        "activity_id",
        "entity_type",
        "activity_kind",
        "title",
        "status",
        "contact_refs",
        "binder_refs",
        "source_provenance",
        "sync"
      ],
      "properties": {
        "activity_id": {
          "$ref": "#/$defs/activity_id"
        },
        "entity_type": {
          "const": "activity"
        },
        "activity_kind": {
          "type": "string",
          "enum": ["task", "note", "email", "meeting", "reminder", "issue", "event", "webhook"]
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "body": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["open", "queued", "in_progress", "done", "cancelled", "failed"]
        },
        "occurred_at": {
          "$ref": "#/$defs/timestamp"
        },
        "due_at": {
          "$ref": "#/$defs/timestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/timestamp"
        },
        "contact_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entity_ref"
          }
        },
        "company_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entity_ref"
          }
        },
        "binder_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entity_ref"
          }
        },
        "source_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_provenance"
          }
        },
        "sync": {
          "$ref": "#/$defs/sync_state"
        }
      },
      "additionalProperties": false
    },
    "binder_project": {
      "type": "object",
      "required": [
        "object_id",
        "entity_type",
        "object_kind",
        "canonical_tag",
        "title",
        "status",
        "routing",
        "source_provenance",
        "sync"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/binder_id"
        },
        "entity_type": {
          "const": "binder_project"
        },
        "object_kind": {
          "type": "string",
          "enum": ["binder", "project"]
        },
        "canonical_tag": {
          "type": "string",
          "pattern": "^#(binder|project)/[a-z0-9][a-z0-9._-]*$"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "paused", "blocked", "archived", "completed"]
        },
        "contact_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entity_ref"
          }
        },
        "company_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entity_ref"
          }
        },
        "routing": {
          "type": "object",
          "required": ["projection_targets"],
          "properties": {
            "projection_targets": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "automation_labels": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "source_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_provenance"
          }
        },
        "sync": {
          "$ref": "#/$defs/sync_state"
        }
      },
      "additionalProperties": false
    },
    "sync_metadata": {
      "type": "object",
      "required": [
        "sync_id",
        "entity_type",
        "subject",
        "source_system",
        "target_system",
        "direction",
        "state",
        "last_attempt_at"
      ],
      "properties": {
        "sync_id": {
          "$ref": "#/$defs/sync_id"
        },
        "entity_type": {
          "const": "sync_metadata"
        },
        "subject": {
          "$ref": "#/$defs/entity_ref"
        },
        "source_system": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_system": {
          "$ref": "#/$defs/non_empty_string"
        },
        "direction": {
          "type": "string",
          "enum": ["push", "pull", "bidirectional"]
        },
        "state": {
          "type": "string",
          "enum": ["pending", "running", "synced", "conflict", "error", "skipped"]
        },
        "last_attempt_at": {
          "$ref": "#/$defs/timestamp"
        },
        "last_success_at": {
          "$ref": "#/$defs/timestamp"
        },
        "next_retry_at": {
          "$ref": "#/$defs/timestamp"
        },
        "error_code": {
          "type": "string"
        },
        "error_message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
