{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/ok-agent-capability-contract.schema.json",
  "title": "uDOS OK Agent Capability Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "schema",
    "summary",
    "required_fields",
    "autonomy_classes",
    "owners"
  ],
  "properties": {
    "version": {
      "const": "v2.0.4"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "schema": {
      "const": "schemas/ok-agent-capability-contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 7
    },
    "autonomy_classes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "owners": {
      "type": "object",
      "required": [
        "contract",
        "managed_policy",
        "contributor_lane"
      ],
      "properties": {
        "contract": {
          "const": "uDOS-core"
        },
        "managed_policy": {
          "const": "uDOS-wizard"
        },
        "contributor_lane": {
          "const": "uDOS-dev"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
