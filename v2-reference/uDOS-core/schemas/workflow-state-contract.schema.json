{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/workflow-state-contract.schema.json",
  "title": "uDOS Workflow State Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "schema",
    "summary",
    "required_fields",
    "status_values",
    "owners"
  ],
  "properties": {
    "version": {
      "const": "v2.0.4"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "schema": {
      "const": "schemas/workflow-state-contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 6
    },
    "status_values": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "owners": {
      "type": "object",
      "required": [
        "contract",
        "policy",
        "durable_execution_consumer",
        "presentation_consumers"
      ],
      "properties": {
        "contract": {
          "const": "uDOS-core"
        },
        "policy": {
          "const": "uDOS-wizard"
        },
        "durable_execution_consumer": {
          "const": "uHOME-server"
        },
        "presentation_consumers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
