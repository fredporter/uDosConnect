{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UCI Prediction Contract",
  "type": "object",
  "required": [
    "version",
    "input",
    "mode",
    "suggestions"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "input": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "nav",
        "text",
        "command",
        "edit",
        "game",
        "media"
      ]
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "value",
          "source",
          "rank"
        ],
        "properties": {
          "value": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "dictionary",
              "history",
              "command_registry",
              "binder_cache",
              "domain_vocabulary",
              "local_reranker",
              "wizard_reranker"
            ]
          },
          "rank": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
