{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/script-document-contract.schema.json",
  "title": "uDOS Script Document Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "schema",
    "summary",
    "file_suffix",
    "frontmatter_fields",
    "type_value",
    "version_value",
    "runtime_values",
    "block_types",
    "execution_surfaces",
    "owners"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "schema": {
      "const": "schemas/script-document-contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "file_suffix": {
      "const": "-script.md"
    },
    "frontmatter_fields": {
      "type": "object",
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "type_value": {
      "const": "script"
    },
    "version_value": {
      "type": "integer"
    },
    "runtime_values": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["tui", "web"]
      },
      "minItems": 1
    },
    "permission_values": {
      "type": "array",
      "items": { "type": "string" }
    },
    "block_types": {
      "type": "object",
      "required": ["ucode", "story", "asset"],
      "properties": {
        "ucode": { "type": "string" },
        "story": { "type": "string" },
        "asset": { "type": "string" }
      },
      "additionalProperties": false
    },
    "execution_surfaces": {
      "type": "object",
      "required": ["tui_go", "web_typescript"],
      "properties": {
        "tui_go": {
          "type": "object",
          "required": ["entry", "flow"],
          "properties": {
            "entry": { "type": "string" },
            "flow": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          },
          "additionalProperties": false
        },
        "web_typescript": {
          "type": "object",
          "required": ["flow"],
          "properties": {
            "flow": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "owners": {
      "type": "object",
      "required": [
        "contract",
        "frontmatter_parsing",
        "ucode_dispatch",
        "story_rendering",
        "presentation_theming",
        "authoring"
      ],
      "properties": {
        "contract": { "const": "uDOS-core" },
        "frontmatter_parsing": { "type": "string" },
        "ucode_dispatch": { "type": "string" },
        "story_rendering": { "type": "string" },
        "presentation_theming": { "type": "string" },
        "authoring": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
