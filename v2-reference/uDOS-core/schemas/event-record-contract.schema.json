{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/event-record-contract.schema.json",
  "title": "uDOS Event Record Contract",
  "type": "object",
  "required": ["id", "ts", "class", "type", "summary"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "class": {
      "type": "string",
      "enum": ["event", "ops", "diagnostic", "metric"]
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
