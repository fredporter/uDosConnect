{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/budget-policy-contract.schema.json",
  "title": "uDOS Budget Policy Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "schema",
    "summary",
    "required_fields",
    "budget_groups",
    "owners"
  ],
  "properties": {
    "version": {
      "const": "v2.0.4"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "schema": {
      "const": "schemas/budget-policy-contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 6
    },
    "budget_groups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "owners": {
      "type": "object",
      "required": [
        "contract",
        "live_budget_owner",
        "simulation_owner"
      ],
      "properties": {
        "contract": {
          "const": "uDOS-core"
        },
        "live_budget_owner": {
          "const": "uDOS-wizard"
        },
        "simulation_owner": {
          "const": "uDOS-dev"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
