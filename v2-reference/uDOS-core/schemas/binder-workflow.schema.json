{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "uDOS v2 Binder Workflow",
  "type": "object",
  "required": ["binder", "owner", "state", "objective"],
  "properties": {
    "binder": {
      "type": "string",
      "pattern": "^#binder/"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["pending", "in-progress", "blocked", "completed"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "validation_path": {
      "type": "string"
    },
    "promotion_target": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
