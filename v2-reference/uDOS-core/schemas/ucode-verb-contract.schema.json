{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/ucode-verb-contract.schema.json",
  "title": "uDOS uCode Verb Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "schema",
    "summary",
    "verb_pattern",
    "dispatch_owner",
    "core_verbs",
    "examples",
    "grammar_rules",
    "owners"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "schema": {
      "const": "schemas/ucode-verb-contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "verb_pattern": {
      "type": "string"
    },
    "dispatch_owner": {
      "type": "string"
    },
    "core_verbs": {
      "type": "object",
      "description": "Verb groups keyed by category. Values are arrays of verb strings.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "grammar_rules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "owners": {
      "type": "object",
      "required": [
        "contract",
        "parsing_and_dispatch",
        "verb_surface_consumers"
      ],
      "properties": {
        "contract": {
          "const": "uDOS-core"
        },
        "parsing_and_dispatch": {
          "type": "string"
        },
        "verb_surface_consumers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
