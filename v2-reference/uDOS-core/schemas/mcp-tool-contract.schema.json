{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/mcp-tool-contract.schema.json",
  "title": "uDOS MCP Tool Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "schema",
    "summary",
    "required_fields",
    "schedule_classes",
    "owners"
  ],
  "properties": {
    "version": {
      "const": "v2.0.4"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "schema": {
      "const": "schemas/mcp-tool-contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 10
    },
    "schedule_classes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "owners": {
      "type": "object",
      "required": [
        "contract",
        "managed_mcp_owner",
        "fixture_validation_owner"
      ],
      "properties": {
        "contract": {
          "const": "uDOS-core"
        },
        "managed_mcp_owner": {
          "const": "uDOS-wizard"
        },
        "fixture_validation_owner": {
          "const": "uDOS-dev"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
