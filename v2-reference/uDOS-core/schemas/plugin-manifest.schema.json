{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "uDOS v2 Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "capability", "trust"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "trust": {
      "type": "string",
      "enum": ["certified", "community", "local"]
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "core": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        },
        "wizard": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
