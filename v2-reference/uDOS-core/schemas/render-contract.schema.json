{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/render-contract.schema.json",
  "title": "uDOS Render Contract",
  "type": "object",
  "required": [
    "version",
    "owner",
    "compile_rule",
    "render_document_contract",
    "metadata_fields",
    "targets",
    "theme_contract",
    "output_manifest_contract"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "owner": {
      "const": "uDOS-core"
    },
    "summary": {
      "type": "string"
    },
    "compile_rule": {
      "type": "string"
    },
    "render_document_contract": {
      "type": "object",
      "required": [
        "version",
        "input",
        "intermediate_representation",
        "base_transform"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "input": {
          "type": "string"
        },
        "intermediate_representation": {
          "type": "string"
        },
        "base_transform": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metadata_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "targets": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "mode",
          "surface_owner",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "surface_owner": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "theme_contract": {
      "type": "object",
      "required": [
        "theme_owner",
        "required_refs",
        "optional_refs"
      ],
      "properties": {
        "theme_owner": {
          "const": "uDOS-themes"
        },
        "required_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "output_manifest_contract": {
      "type": "object",
      "required": [
        "fields"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 4
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
