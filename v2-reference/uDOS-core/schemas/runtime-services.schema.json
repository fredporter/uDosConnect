{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udos.dev/schemas/runtime-services.schema.json",
  "title": "uDOS Runtime Services",
  "type": "object",
  "required": ["version", "extends", "count", "services"],
  "properties": {
    "version": {
      "type": "string"
    },
    "extends": {
      "type": "string"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "owner", "route", "stability", "consumers", "notes"],
        "properties": {
          "key": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "stability": {
            "type": "string"
          },
          "consumers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
