<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{title}}</title>
  <id>{{id}}</id>
  <updated>{{updated}}</updated>
  <link href="{{link}}" />

  {{#items}}
  <entry>
    <id>{{id}}</id>
    <title>{{title}}</title>
    <updated>{{ts}}</updated>
    <summary>{{summary}}</summary>
  </entry>
  {{/items}}
</feed>
