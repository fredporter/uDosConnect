<rss version="2.0">
  <channel>
    <title>{{title}}</title>
    <link>{{link}}</link>
    <description>{{description}}</description>

    {{#items}}
    <item>
      <title>{{title}}</title>
      <description>{{summary}}</description>
      <pubDate>{{ts}}</pubDate>
      <guid>{{id}}</guid>
    </item>
    {{/items}}
  </channel>
</rss>
