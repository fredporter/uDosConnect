{
  "version": "v2.0.4",
  "owner": "uDOS-core",
  "schema": "schemas/automation-result-contract.schema.json",
  "summary": "Minimal automation result contract for durable execution feedback into workflow and presentation layers.",
  "required_fields": [
    "job_id",
    "status",
    "output_refs",
    "event_refs",
    "completed_at",
    "suggested_workflow_action"
  ],
  "status_values": [
    "queued",
    "running",
    "completed",
    "failed",
    "cancelled"
  ],
  "owners": {
    "contract": "uDOS-core",
    "fulfillment_owner": "uHOME-server",
    "workflow_consumer": "uDOS-wizard",
    "presentation_consumers": [
      "private-desktop-client",
      "uDOS-gameplay"
    ]
  }
}
