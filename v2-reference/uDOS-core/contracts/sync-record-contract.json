{
  "version": "v2.0.4",
  "extends": "v2.0.2",
  "owner": "uDOS-core",
  "schema": "schemas/sync-record-contract.schema.json",
  "record_types": [
    {
      "key": "canonical_contact",
      "id_field": "contact_id",
      "required_fields": [
        "contact_id",
        "entity_type",
        "display_name",
        "emails",
        "phones",
        "addresses",
        "external_refs",
        "source_provenance",
        "first_seen_at",
        "last_seen_at"
      ],
      "notes": "Canonical contact identity used for local-first contact resolution and projection mapping."
    },
    {
      "key": "activity",
      "id_field": "activity_id",
      "required_fields": [
        "activity_id",
        "entity_type",
        "activity_kind",
        "title",
        "status",
        "contact_refs",
        "binder_refs",
        "source_provenance",
        "sync"
      ],
      "notes": "Normalized activity object for tasks, notes, meetings, reminders, issues, and email-derived events."
    },
    {
      "key": "binder_project",
      "id_field": "object_id",
      "required_fields": [
        "object_id",
        "entity_type",
        "object_kind",
        "canonical_tag",
        "title",
        "status",
        "routing",
        "source_provenance",
        "sync"
      ],
      "notes": "Shared binder and project record used for deterministic routing and association lookup."
    },
    {
      "key": "sync_metadata",
      "id_field": "sync_id",
      "required_fields": [
        "sync_id",
        "entity_type",
        "subject",
        "source_system",
        "target_system",
        "direction",
        "state",
        "last_attempt_at"
      ],
      "notes": "Transport-neutral sync state used to track projections, retries, conflicts, and provenance."
    }
  ],
  "envelope": {
    "required_collections": [
      "contacts",
      "activities",
      "binders",
      "sync_metadata"
    ],
    "notes": "Repos may exchange one or more collections together, but each record must conform to the shared schema definitions."
  }
}
