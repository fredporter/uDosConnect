{
  "version": "v2.0.4",
  "owner": "uDOS-core",
  "schema": "schemas/ucode-verb-contract.schema.json",
  "summary": "Canonical uCode verb contract. Defines the deterministic command DSL dispatched by the Core runtime. uCode is not a general programming language — it is the operational language of uDOS.",
  "verb_pattern": "<VERB> [<TARGET>] [<VALUE>]",
  "dispatch_owner": "uDOS-core runtime",
  "core_verbs": {
    "state": ["SET", "UNSET", "GET"],
    "status": ["STATUS", "MAP", "INSPECT"],
    "workflow": ["WORKFLOW RUN", "WORKFLOW PAUSE", "WORKFLOW RESUME", "WORKFLOW STATUS"],
    "binder": ["BINDER START", "BINDER STATUS", "BINDER CLOSE"],
    "script": ["SCRIPT RUN", "RUN"],
    "draw": ["DRAW BLOCK", "DRAW PAT", "DRAW SCENE"]
  },
  "examples": [
    "SET system.status startup",
    "STATUS",
    "MAP",
    "BINDER STATUS system",
    "WORKFLOW RUN onboarding",
    "SCRIPT RUN startup",
    "DRAW BLOCK assets/ucodesmile-ascii.md",
    "DRAW PAT TEXT \"Startup ready\""
  ],
  "grammar_rules": [
    "Verbs are uppercase",
    "Arguments follow the verb separated by whitespace",
    "String values are quoted with double quotes",
    "Variable references use $prefix notation",
    "Avoid language-style variable assignment (no = operator)"
  ],
  "owners": {
    "contract": "uDOS-core",
    "parsing_and_dispatch": "uDOS-core runtime",
    "verb_surface_consumers": [
      "uDOS-shell",
      "uDOS-wizard",
      "uDOS-gameplay"
    ]
  }
}
