{
  "version": "v2.0.3",
  "owner": "uDOS-core",
  "summary": "Shared render contract for semantic HTML and reader-facing output adapters derived from compiled artifacts.",
  "compile_rule": "compile creates the canonical artifact; render adapters derive reader-facing outputs",
  "render_document_contract": {
    "version": "v2.0.3",
    "input": "compiled-binder-artifact",
    "intermediate_representation": "render-document",
    "base_transform": "markdown-frontmatter-to-semantic-html"
  },
  "metadata_fields": [
    "prose_preset",
    "theme_adapter",
    "render_targets",
    "skin_id",
    "lens_id"
  ],
  "targets": [
    {
      "id": "web-prose",
      "mode": "html",
      "surface_owner": "shared-consumer",
      "notes": "Primary prose-style web output."
    },
    {
      "id": "email-html",
      "mode": "html-email-safe",
      "surface_owner": "shared-consumer",
      "notes": "Email-safe HTML derived from the same render document."
    },
    {
      "id": "gui-preview",
      "mode": "preview-fragment",
      "surface_owner": "shared-consumer",
      "notes": "Wizard GUI and Thin GUI preview payload."
    },
    {
      "id": "beacon-library",
      "mode": "html-library",
      "surface_owner": "shared-consumer",
      "notes": "Nearby library presentation behind Beacon Activate."
    }
  ],
  "theme_contract": {
    "theme_owner": "uDOS-themes",
    "required_refs": [
      "prose_preset",
      "theme_adapter"
    ],
    "optional_refs": [
      "skin_id",
      "lens_id"
    ]
  },
  "output_manifest_contract": {
    "fields": [
      "target",
      "artifact_id",
      "theme_adapter",
      "prose_preset",
      "output_path",
      "content_type"
    ]
  }
}
