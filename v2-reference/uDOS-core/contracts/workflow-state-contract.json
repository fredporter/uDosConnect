{
  "version": "v2.0.4",
  "owner": "uDOS-core",
  "schema": "schemas/workflow-state-contract.schema.json",
  "summary": "Minimal shared workflow state contract for Wizard authority, app touchpoints, uHOME automation handoff, and gameplay interpretation.",
  "required_fields": [
    "workflow_id",
    "step_id",
    "status",
    "awaiting_user_action",
    "last_transition_at",
    "origin_surface"
  ],
  "status_values": [
    "draft",
    "ready",
    "running",
    "paused",
    "blocked",
    "completed",
    "failed"
  ],
  "owners": {
    "contract": "uDOS-core",
    "policy": "uDOS-wizard",
    "durable_execution_consumer": "uHOME-server",
    "presentation_consumers": [
      "private-desktop-client",
      "uDOS-gameplay"
    ]
  }
}
