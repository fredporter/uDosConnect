{
  "version": "v2.0.4",
  "owner": "uDOS-core",
  "schema": "schemas/workflow-action-contract.schema.json",
  "summary": "Minimal explicit workflow action contract for conscious user-directed transitions and approval gates.",
  "required_fields": [
    "workflow_id",
    "action",
    "requested_by",
    "requested_at",
    "policy_flags"
  ],
  "action_values": [
    "advance",
    "pause",
    "resume",
    "approve",
    "reject",
    "request-assist",
    "replan"
  ],
  "owners": {
    "contract": "uDOS-core",
    "policy": "uDOS-wizard",
    "touch_consumers": [
      "private-desktop-client",
      "uHOME-client"
    ]
  }
}
