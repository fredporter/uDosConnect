{
  "service": "google-mvp-binder-trigger",
  "status": "legacy-transition",
  "lane_id": "google-mvp-a",
  "transport": "http",
  "auth": "service-account-or-shared-secret",
  "base_url": "https://google-mvp.example.invalid",
  "route": "/binder/google-mvp/mirror",
  "source_of_truth": "vault",
  "operations": [
    "binder.trigger.receive",
    "artifact.mirror.approved",
    "mirror.status.emit"
  ],
  "mirror_rules": {
    "canonical_truth": "vault",
    "remote_role": "firestore-mirror",
    "approved_artifact_types": [
      "binder_project",
      "activity",
      "sync_metadata"
    ]
  },
  "extraction_required": [
    "route list",
    "Firestore collection and field summary",
    "environment variable list",
    "auth model summary",
    "budget profile",
    "mirror-eligibility rules"
  ],
  "notes": "First Empire-owned Google MVP binder-trigger lane. Firestore remains mirror-only."
}
