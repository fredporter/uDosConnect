{
  "version": "v2.3.0-draft",
  "owner": "uDOS-empire",
  "record_host": "wordpress-user",
  "default_role": "subscriber",
  "required_fields": [
    "user_email",
    "display_name",
    "consent_status"
  ],
  "user_meta_fields": [
    "mobile_phone",
    "alternate_phone",
    "company_name",
    "job_title",
    "source_channel",
    "lifecycle_stage",
    "import_source",
    "import_batch_id",
    "binder_links",
    "workspace_links",
    "tags",
    "empire_contact_notes",
    "last_contacted_at",
    "last_activity_at",
    "external_reference_ids",
    "social_urls"
  ],
  "matching_precedence": [
    "external_reference_ids",
    "user_email",
    "mobile_phone"
  ],
  "notes_rule": {
    "mode": "append-only-default",
    "format": "udos-log-lines"
  }
}
