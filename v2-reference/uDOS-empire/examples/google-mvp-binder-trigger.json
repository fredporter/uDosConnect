{
  "service": "google-mvp-binder-trigger",
  "lane_id": "google-mvp-a",
  "source_of_truth": "vault",
  "inbound": {
    "enabled": true,
    "path": "/binder/google-mvp/mirror",
    "verification": "shared-secret"
  },
  "artifact": {
    "artifact_ref": "binder://release/weekly-bulletin-2026-03-26",
    "artifact_type": "binder_project",
    "workflow_id": "weekly-bulletin",
    "approved_for_mirror": true
  },
  "target": {
    "remote_role": "firestore-mirror",
    "collection": "binder_artifacts",
    "record_key": "weekly-bulletin-2026-03-26"
  },
  "required_extraction": [
    "route list",
    "Firestore collection and field summary",
    "environment variable list",
    "auth model summary",
    "budget profile",
    "mirror-eligibility rules"
  ],
  "status_emit": {
    "target_system": "google",
    "state": "pending"
  }
}
