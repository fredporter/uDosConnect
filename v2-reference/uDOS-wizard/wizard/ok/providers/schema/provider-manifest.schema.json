{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wizard.ok.provider-manifest.v2.schema.json",
  "title": "Wizard OK Provider Manifest",
  "type": "object",
  "required": [
    "provider_id",
    "provider_class",
    "network_required",
    "models",
    "capabilities",
    "budget_group",
    "retry_policy",
    "cache_policy",
    "approval_required"
  ],
  "properties": {
    "provider_id": {
      "type": "string"
    },
    "provider_class": {
      "type": "string"
    },
    "network_required": {
      "type": "boolean"
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "budget_group": {
      "type": "string"
    },
    "retry_policy": {
      "type": "string"
    },
    "cache_policy": {
      "type": "string"
    },
    "approval_required": {
      "type": "boolean"
    },
    "enabled": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
