{
  "name": "udos-wizard-mcp-client",
  "displayName": "uDOS Wizard MCP Client",
  "description": "VS Code command client for Wizard-managed MCP over HTTP JSON-RPC.",
  "version": "0.2.2",
  "publisher": "fredporter",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:udosWizardMcp.initialize",
    "onCommand:udosWizardMcp.listTools",
    "onCommand:udosWizardMcp.callTool",
    "onCommand:udosWizardMcp.routeSelection"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "udosWizardMcp.initialize",
        "title": "uDOS Wizard MCP: Initialize"
      },
      {
        "command": "udosWizardMcp.listTools",
        "title": "uDOS Wizard MCP: List Tools"
      },
      {
        "command": "udosWizardMcp.callTool",
        "title": "uDOS Wizard MCP: Call Tool"
      },
      {
        "command": "udosWizardMcp.routeSelection",
        "title": "uDOS Wizard MCP: Route Active Selection"
      }
    ],
    "configuration": {
      "title": "uDOS Wizard MCP",
      "properties": {
        "udosWizard.mcpEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:8787/mcp",
          "description": "Wizard MCP HTTP JSON-RPC endpoint."
        }
      }
    }
  }
}
