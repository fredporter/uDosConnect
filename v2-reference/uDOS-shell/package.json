{
  "name": "udos-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "go:run": "go run ./cmd/ucode",
    "first-run": "bash scripts/first-run-launch.sh",
    "test": "node --test dist/tests/*.js",
    "check": "bash scripts/run-shell-checks.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1"
  }
}
