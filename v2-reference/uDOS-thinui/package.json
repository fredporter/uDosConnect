{
  "name": "udos-thinui",
  "version": "2.3.0",
  "private": true,
  "type": "module",
  "description": "Low-resource fullscreen GUI runtime for uDOS",
  "scripts": {
    "check": "bash scripts/run-thinui-checks.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate:binder-spine": "tsx scripts/validate-binder-spine-payload.ts",
    "demo": "tsx scripts/demo-thinui-run.ts",
    "demo:tour": "tsx scripts/demo-thinui-run.ts --tour",
    "dev": "vite --config vite.config.ts",
    "dev:workspace": "vite --config vite.config.ts --open /workspace.html",
    "build:demo": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
