{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "paths": {
      "@thinui/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "demo/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
